{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "outDir": "./dist/preload",
    "rootDir": "./src/preload"
  },
  "include": ["src/preload/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
