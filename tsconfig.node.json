{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@services/*": ["electron/services/*"],
      "@data/*": ["electron/data/*"],
      "@ipc/*": ["electron/ipc/*"],
      "@utils/*": ["electron/utils/*"],
      "@skills/*": ["electron/skills/*"],
      "@vector/*": ["electron/vector/*"],
      "@channels/*": ["electron/channels/*"]
    }
  },
  "include": ["electron/**/*.ts", "electron.vite.config.ts"]
}
